// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  OWNER
  ADMIN
  MEMBER
  VIEWER
}

enum CustomerStatus {
  PREMIUM
  ACTIVE
  INACTIVE
}

enum LeadStatus {
  NEW
  CONTACTED
  PROPOSAL_SENT
  WON
  LOST
}

enum TaskPriority {
  HIGH
  MEDIUM
  LOW
}

enum TaskStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
}

enum QuotationStatus {
  PENDING
  APPROVED
  REJECTED
  EXPIRED
}

model Tenant {
  id        String   @id @default(uuid())
  name      String
  slug      String   @unique
  plan      String   @default("free")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?

  users      TenantUser[]
  customers  Customer[]
  leads      Lead[]
  tasks      Task[]
  quotations Quotation[]
}

model User {
  id               String    @id @default(uuid())
  name             String
  email            String    @unique
  password         String
  resetToken       String?
  resetTokenExpiry DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  deletedAt        DateTime?

  memberships      TenantUser[]
}

model TenantUser {
  id        String   @id @default(uuid())
  tenantId  String
  userId    String
  role      Role     @default(MEMBER)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([tenantId, userId])
  @@index([tenantId])
  @@index([userId])
}

model Customer {
  id            String         @id @default(uuid())
  tenantId      String
  name          String
  company       String
  email         String?
  status        CustomerStatus @default(ACTIVE)
  revenue       Decimal        @default(0) @db.Decimal(12, 2)
  lastContactAt DateTime?
  manager       String         @default("Unassigned")
  createdBy     String?
  updatedBy     String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  deletedAt     DateTime?

  tenant        Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, status])
  @@index([tenantId, createdAt])
}

model Lead {
  id         String     @id @default(uuid())
  tenantId   String
  name       String
  company    String
  email      String
  status     LeadStatus @default(NEW)
  value      Decimal    @default(0) @db.Decimal(12, 2)
  followUpAt DateTime?
  assignedTo String     @default("Unassigned")
  createdBy  String?
  updatedBy  String?
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt
  deletedAt  DateTime?

  tenant     Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, status])
  @@index([tenantId, createdAt])
}

model Task {
  id          String       @id @default(uuid())
  tenantId    String
  title       String
  description String?
  dueDate     DateTime?
  priority    TaskPriority @default(MEDIUM)
  assignedTo  String       @default("Unassigned")
  status      TaskStatus   @default(PENDING)
  createdBy   String?
  updatedBy   String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  deletedAt   DateTime?

  tenant      Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, status])
  @@index([tenantId, dueDate])
  @@index([tenantId, createdAt])
}

model Quotation {
  id          String          @id @default(uuid())
  tenantId    String
  quoteNumber String
  client      String
  amount      Decimal         @default(0) @db.Decimal(12, 2)
  status      QuotationStatus @default(PENDING)
  validTill   DateTime?
  createdBy   String?
  updatedBy   String?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  deletedAt   DateTime?

  tenant      Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, quoteNumber])
  @@index([tenantId, status])
  @@index([tenantId, createdAt])
}
