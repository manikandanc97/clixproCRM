// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  ADMIN
  MANAGER
  SALES
  EMPLOYEE
}

enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

enum CustomerStatus {
  PREMIUM
  ACTIVE
  INACTIVE
}

enum LeadStatus {
  NEW
  CONTACTED
  PROPOSAL_SENT
  WON
  LOST
}

enum TaskPriority {
  HIGH
  MEDIUM
  LOW
}

enum TaskStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
}

enum QuotationStatus {
  PENDING
  APPROVED
  REJECTED
  EXPIRED
}

model Tenant {
  id        String   @id @default(uuid())
  name      String
  slug      String   @unique
  plan      String   @default("free")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users      TenantUser[]
  customers  Customer[]
  leads      Lead[]
  tasks      Task[]
  quotations Quotation[]
}

model User {
  id               String      @id @default(uuid())
  name             String
  email            String      @unique
  password         String
  status           UserStatus  @default(ACTIVE)
  resetToken       String?
  resetTokenExpiry DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  memberships TenantUser[]
}

model TenantUser {
  id        String   @id @default(uuid())
  tenantId  String
  userId    String
  role      Role     @default(EMPLOYEE)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([tenantId, userId])
  @@index([tenantId])
  @@index([userId])
}

model Customer {
  id            String         @id @default(uuid())
  tenantId      String
  name          String
  company       String
  email         String?
  status        CustomerStatus @default(ACTIVE)
  revenue       Decimal        @default(0) @db.Decimal(12, 2)
  lastContactAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, status])
}

model Lead {
  id         String     @id @default(uuid())
  tenantId   String
  name       String
  company    String
  email      String
  status     LeadStatus @default(NEW)
  value      Decimal    @default(0) @db.Decimal(12, 2)
  followUpAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, status])
}

model Task {
  id          String       @id @default(uuid())
  tenantId    String
  title       String
  description String?
  dueDate     DateTime?
  priority    TaskPriority @default(MEDIUM)
  status      TaskStatus   @default(PENDING)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, status])
}

model Quotation {
  id          String          @id @default(uuid())
  tenantId    String
  quoteNumber String
  client      String
  amount      Decimal         @default(0) @db.Decimal(12, 2)
  status      QuotationStatus @default(PENDING)
  validTill   DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, quoteNumber])
}
